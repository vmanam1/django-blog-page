# Core Django settings
DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DATABASE_URL=sqlite:///db.sqlite3

# Email is printed to the terminal by default during local development.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For SMTP, set the backend below and provide credentials.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@example.com
# EMAIL_HOST_PASSWORD=use-an-app-password-not-your-account-password
# DEFAULT_FROM_EMAIL=you@example.com

# Optional AWS S3 media storage. If the bucket is omitted, local media is used.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=eu-north-1
